# Backend Environment Variables
# Copy this to .env and fill in your values

PORT=3001
NODE_ENV=development

# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/transportes_genesis

# JWT secret - use a long random string in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# For Railway deployment, these are set automatically
# DATABASE_URL is injected by Railway PostgreSQL plugin
